# Hortator environment configuration.
#
# Copy this file to `.env` at the repo root (or at any ancestor directory you
# load from a shell profile / direnv) and fill in the values. The escript and
# mix tasks read from the process environment, so any mechanism that puts
# these in your shell will work — direnv `.envrc`, `source .env`, 1Password
# CLI, etc.
#
# NEVER commit `.env`. It's in .gitignore. Treat LINEAR_API_KEY like a password.

# ── Linear tracker ─────────────────────────────────────────────────────────
# Personal API token. Create at: Linear → Settings → Security & access.
LINEAR_API_KEY=lin_api_REPLACE_ME

# Project slug that the orchestrator polls for work. Right-click a Linear
# project and copy URL; the slug is the trailing path segment.
LINEAR_PROJECT_SLUG=your-project-slug

# Separate project slug used by `make e2e` so the live test can create and
# burn through disposable issues without polluting the production project
# above. Typically points at a scratch "testing" project in Linear.
# LINEAR_TEST_PROJECT_SLUG=your-test-project-slug

# Optional: only claim issues assigned to this user. Resolves to the viewer
# (whoever owns LINEAR_API_KEY) when left unset.
# LINEAR_ASSIGNEE=user@example.com

# ── Workspaces ─────────────────────────────────────────────────────────────
# Directory where each issue gets its own sub-workspace. Must not be inside a
# source repo. `~` expansion is supported.
WORKSPACE_ROOT=~/code/hortator-workspaces

# Clone URL used by `hooks.after_create` in WORKFLOW.md to populate a new
# workspace. SSH form (git@…) or HTTPS both work.
REPO_CLONE_URL=git@github.com:your-org/your-repo.git

# ── Claude Code agent backend ──────────────────────────────────────────────
# Forwarded to the Claude Code subprocess; enables agent-team features.
CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS=1

# ── Live / end-to-end tests (optional) ─────────────────────────────────────
# `make e2e` is gated on this flag so the live test never fires accidentally.
# It will create a disposable issue in the project named by LINEAR_PROJECT_SLUG
# (above), run a real Claude Code session against it, then verify the agent
# completed the work.
# HORTATOR_RUN_LIVE_E2E=1

# Comma-separated SSH hosts to target for the SSH worker scenario in live
# tests. When unset, the live test spins up disposable Docker workers.
# HORTATOR_LIVE_SSH_WORKER_HOSTS=host1.example.com,host2.example.com

# ── Hortator runtime overrides (optional) ──────────────────────────────────
# Explicit workflow file path; otherwise the escript / mix task looks for
# ./WORKFLOW.md at its cwd.
# HORTATOR_WORKFLOW_FILE=/absolute/path/to/WORKFLOW.md

# Path to an SSH config file, forwarded into Transport.SSH for remote workers.
# HORTATOR_SSH_CONFIG=~/.ssh/hortator_workers

# ── Smoke-test workflow (optional) ─────────────────────────────────────────
# Used by workflows/smoke-test.md; safe to omit for normal runs.
# SMOKE_WORKSPACE_ROOT=~/code/hortator-smoke-workspaces
# SMOKE_REPO_URL=git@github.com:your-org/your-repo.git
# SMOKE_REPO_BRANCH=smoke-test
