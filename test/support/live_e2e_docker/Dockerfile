FROM node:20-bookworm-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    bash \
    ca-certificates \
    git \
    openssh-server \
    python3 \
    ripgrep \
  && rm -rf /var/lib/apt/lists/*

RUN useradd -m -s /bin/bash worker \
  && passwd -d worker \
  && install -d -m 700 -o worker -g worker /home/worker/.ssh \
  && install -d -m 700 /run/symphony/ssh /var/run/sshd

RUN npm install --global @anthropic-ai/claude-code

COPY hortator-live-worker.conf /etc/ssh/sshd_config.d/hortator-live-worker.conf
COPY live_worker_entrypoint.sh /usr/local/bin/hortator-live-worker
RUN chmod 755 /usr/local/bin/hortator-live-worker

EXPOSE 22

ENTRYPOINT ["/usr/local/bin/hortator-live-worker"]
